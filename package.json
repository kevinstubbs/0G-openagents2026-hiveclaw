{
  "name": "hiveclaw",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "docs:dashboard": "pnpm --filter hiveclaw-dashboard docs:dev",
    "docs:build": "pnpm --filter hiveclaw-dashboard docs:build",
    "build": "pnpm run docs:build && pnpm -r --filter '!hiveclaw-dashboard-docs' run build",
    "build:vercel": "pnpm --filter hiveclaw-core run build && pnpm --filter hiveclaw-dashboard run build",
    "test": "forge test --root contracts",
    "doctor": "node apps/hiveclaw-cli/dist/cli.js doctor",
    "healthcheck": "node apps/hiveclaw-cli/dist/cli.js doctor",
    "deploy:testnet": "dotenv -e .env -- bash contracts/deploy-testnet.sh",
    "openclaw:plugin": "bash scripts/install-openclaw-hiveclaw-plugin.sh"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
