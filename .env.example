# 0G Galileo testnet (chain id 16602) — https://docs.0g.ai/developer-hub/testnet/testnet-overview
HIVECLAW_RPC_URL=https://evmrpc-testnet.0g.ai
HIVECLAW_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Next.js can also read these public names (server components use them as fallback):
# NEXT_PUBLIC_HIVECLAW_RPC_URL=https://evmrpc-testnet.0g.ai
# NEXT_PUBLIC_HIVECLAW_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Deployed contract addresses (canonical testnet deployment — full table in README).
HIVECLAW_BOOTSTRAP_CONTRACT=0x4e6A80653B419777d281622249bd49Dc35131005
NEXT_PUBLIC_HIVECLAW_BOOTSTRAP_CONTRACT=0x4e6A80653B419777d281622249bd49Dc35131005

HIVECLAW_HIVE_REGISTRY_CONTRACT=0x496A34251Da57a3C1907325884323147D549626A
NEXT_PUBLIC_HIVECLAW_HIVE_REGISTRY_CONTRACT=0x496A34251Da57a3C1907325884323147D549626A

# CLI chain txs + Forge deploy scripts: funded deployer key (never commit a real key).
# Forge scripts expect PRIVATE_KEY; hiveclaw-core CLI uses HIVECLAW_CHAIN_PRIVATE_KEY then PRIVATE_KEY.
# deploy-testnet.sh sets PRIVATE_KEY from HIVECLAW_CHAIN_PRIVATE_KEY when PRIVATE_KEY is unset.
# PRIVATE_KEY=0x...
# HIVECLAW_CHAIN_PRIVATE_KEY=0x...

# Optional: funded testnet key for 0G Storage upload/download smoke (never commit real keys)
HIVECLAW_STORAGE_PRIVATE_KEY=

# Expected chain id (optional sanity check in doctor output)
HIVECLAW_EXPECTED_CHAIN_ID=16602

# Deploy both contracts (recommended): loads .env via dotenv-cli (no key on the command line).
# Prints .env lines to the console and writes contracts/deployments/<chainId>.json
#   pnpm deploy:testnet
# Manual (same as above):
#   dotenv -e .env -- bash contracts/deploy-testnet.sh
# One-liner with forge (still use dotenv for the key):
#   dotenv -e .env -- bash -c 'cd contracts && forge script script/DeployHiveClaw.s.sol:DeployHiveClaw --rpc-url og_testnet --broadcast -vvv'
#
# Individual redeploys (advanced, same dotenv pattern):
#   dotenv -e .env -- bash -c 'cd contracts && forge script script/DeployBootstrap.s.sol:DeployBootstrap --rpc-url https://evmrpc-testnet.0g.ai --broadcast'
#   dotenv -e .env -- bash -c 'cd contracts && forge script script/DeployHiveRegistry.s.sol:DeployHiveRegistry --rpc-url https://evmrpc-testnet.0g.ai --broadcast'
