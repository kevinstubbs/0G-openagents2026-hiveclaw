{
  "id": "hiveclaw",
  "name": "HiveClaw",
  "description": "0G-backed HiveClaw memory backbone (Phase 1: hiveclaw_ping diagnostic tool).",
  "kind": "tool",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rpcUrl": { "type": "string", "description": "0G Chain JSON-RPC URL" },
      "indexerUrl": { "type": "string", "description": "0G Storage indexer URL" },
      "bootstrapContract": { "type": "string", "description": "HiveClawBootstrap contract address (hex)" },
      "storagePrivateKey": { "type": "string", "description": "Optional funded key for storage smoke (prefer gateway secrets)" },
      "expectedChainId": { "type": "integer", "description": "Optional expected chain id (e.g. 16602 testnet)" }
    }
  },
  "activation": {
    "onStartup": true
  }
}
