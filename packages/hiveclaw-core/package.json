  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --test src/**/*.test.ts 2>/dev/null || true"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.8",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
