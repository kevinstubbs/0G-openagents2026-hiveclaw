{
  "gateway": {
    "mode": "local",
    "port": 18790,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": [
      "hiveclaw_ping",
      "hiveclaw_list_my_hives",
      "remember_shared",
      "recall_shared",
      "remember_private",
      "recall_private",
      "summarize_memory",
      "hiveclaw_reflect"
    ]
  },
  "agents": {
    "defaults": {
      "workspace": "demo/rbv/workspaces/builder",
      "model": {
        "primary": "openai/gpt-5.4-mini"
      }
    }
  },
  "plugins": {
    "entries": {
      "hiveclaw": {
        "enabled": true,
        "config": {
          "rpcUrl": "https://evmrpc-testnet.0g.ai",
          "indexerUrl": "https://indexer-storage-testnet-turbo.0g.ai",
          "expectedChainId": 16602,
          "bootstrapContract": "0x4e6A80653B419777d281622249bd49Dc35131005",
          "hiveRegistryContract": "0x496A34251Da57a3C1907325884323147D549626A",
          "defaultHiveId": 1,
          "privateComputerBaseUrl": "https://pc.0g.ai",
          "chainPrivateKey": "${HIVECLAW_CHAIN_PRIVATE_KEY}",
          "storagePrivateKey": "${HIVECLAW_STORAGE_PRIVATE_KEY}",
          "hiveKeysJson": "${HIVECLAW_HIVE_KEYS_JSON}"
        }
      },
      "openai": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.5.2",
    "lastTouchedAt": "2026-05-03T14:13:38.204Z"
  }
}
