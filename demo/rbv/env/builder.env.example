# Copy to builder.env and fill in (never commit real keys).

# Same value as researcher.env / reviewer.env (Control UI).
OPENCLAW_GATEWAY_TOKEN=

OPENAI_API_KEY=

# Builder chain wallet (hive member). Distinct from researcher and reviewer.
HIVECLAW_CHAIN_PRIVATE_KEY=

# Same storage key as researcher.env (demo default).
HIVECLAW_STORAGE_PRIVATE_KEY=

# Must match researcher.env and reviewer.env exactly. See environment.mdx#hive-keys-json in repo docs.
HIVECLAW_HIVE_KEYS_JSON={"1":"0xYOUR_64_HEX_CHARS_HERE"}

HIVECLAW_EXPECTED_CHAIN_ID=16602

