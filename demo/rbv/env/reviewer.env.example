# Copy to reviewer.env and fill in (never commit real keys).

# Same value as researcher.env / builder.env (Control UI).
OPENCLAW_GATEWAY_TOKEN=

OPENAI_API_KEY=

# Reviewer chain wallet (hive member). Distinct from researcher and builder.
