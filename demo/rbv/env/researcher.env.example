# Copy to researcher.env and fill in (never commit real keys).
# Source this file before starting the Researcher gateway (see README).

# Researcher chain wallet (hive member). Distinct from builder and reviewer.
HIVECLAW_CHAIN_PRIVATE_KEY=

# Shared across all three gateways for this demo — one funded 0G storage key.
HIVECLAW_STORAGE_PRIVATE_KEY=

# Same JSON on all three gateways: maps hive id → 32-byte symmetric key (hex).
# Generate a random 32-byte key per hive; share only among demo operators.
HIVECLAW_HIVE_KEYS_JSON={"1":"0xYOUR_64_HEX_CHARS_HERE"}

HIVECLAW_EXPECTED_CHAIN_ID=16602

# Optional: Private Computer API key if your deployment requires it.
# HIVECLAW_PRIVATE_COMPUTER_API_KEY=
